<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GSCFieldApp.Controls.ExpandableFrame"
             xmlns:conv="clr-namespace:GSCFieldApp.Converters">
    <ContentView.Resources>
        
        <!--Converters-->
        <conv:ComboboxItemToString x:Key="cbox2Str"/>
        <conv:VisibilityFromReverseBoolConverter x:Key="reverseBool"/>
        
        <ControlTemplate x:Key="ExpandableFrameControl">

            <Border Stroke="{TemplateBinding FrameColor}" Style="{StaticResource FieldAppSectionBorder}">

                <!--Tap to hide content-->
                <!--<Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{TemplateBinding HideCommand}" NumberOfTapsRequired="{OnIdiom Default=1, Desktop=2, Phone=2, Tablet=2}"/>
                </Border.GestureRecognizers>-->

                <VerticalStackLayout>

                    <!--Title that won't be hidden-->
                    <StackLayout Orientation="Horizontal" Spacing="5">
                        <Label FontSize="Medium" HorizontalTextAlignment="Start"
                               Text="&#xF0140;" FontFamily="MatDesign" Style="{StaticResource FieldAppTitle}" IsVisible="{TemplateBinding FrameContentVisibility}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{TemplateBinding HideCommand}" NumberOfTapsRequired="{OnIdiom Default=1, Desktop=2, Phone=2, Tablet=2}"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <Label FontSize="Medium" HorizontalTextAlignment="Start"
                            Text="&#xF0143;" FontFamily="MatDesign" Style="{StaticResource FieldAppTitle}" IsVisible="{TemplateBinding FrameContentVisibility, Converter={StaticResource reverseBool}}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{TemplateBinding HideCommand}" NumberOfTapsRequired="{OnIdiom Default=1, Desktop=2, Phone=2, Tablet=2}"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Style="{StaticResource FieldAppTitle}"  Text="{TemplateBinding FrameTitle}" >
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{TemplateBinding HideCommand}" NumberOfTapsRequired="{OnIdiom Default=1, Desktop=2, Phone=2, Tablet=2}"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <Label TextColor="{StaticResource Blue100Accent}" FontSize="Medium" HorizontalTextAlignment="End"
                               Text="&#xF02FD;" FontFamily="MatDesign" 
                               IsVisible="{TemplateBinding InfoAlertVisibility}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{TemplateBinding InfoAlertCommand}" NumberOfTapsRequired="1" CommandParameter="{TemplateBinding InfoAlertParameter}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </StackLayout>
                    

                    <!--Stack that will be hidden-->
                    <VerticalStackLayout IsVisible="{TemplateBinding FrameContentVisibility}">
                        
                        <!--Whatever needs to be inserted here from original view-->
                        <ContentPresenter/>
                        
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

        </ControlTemplate>
    </ContentView.Resources>
</ContentView>
